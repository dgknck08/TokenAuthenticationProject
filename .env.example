# Database Configuration
POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=change_me_db_password

# Redis Configuration
REDIS_PASSWORD=change_me_redis_password

# JWT Configuration
JWT_SECRET=change_me_64byte_hex_or_strong_secret
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# App Cookie Policy
# true for HTTPS environments, false only for local HTTP development
APP_COOKIE_SECURE=true

# Email (SMTP / Brevo)
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_brevo_smtp_login
SPRING_MAIL_PASSWORD=your_brevo_smtp_key
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_CONNECTION_TIMEOUT=5000
SPRING_MAIL_SMTP_TIMEOUT=5000
SPRING_MAIL_SMTP_WRITE_TIMEOUT=5000
APP_MAIL_FROM=no-reply@your-domain.com
APP_EMAIL_VERIFICATION_BASE_URL=http://localhost:3000/verify-email
APP_EMAIL_VERIFICATION_EXPIRATION_MS=1800000
APP_PASSWORD_RESET_BASE_URL=http://localhost:3000/auth/reset-password
APP_PASSWORD_RESET_EXPIRATION_MS=900000
APP_IDEMPOTENCY_TTL_HOURS=24

# Iyzico (optional starter settings)
APP_PAYMENT_IYZICO_ENABLED=false
APP_PAYMENT_IYZICO_API_BASE_URL=https://sandbox-api.iyzipay.com
APP_PAYMENT_IYZICO_API_KEY=
APP_PAYMENT_IYZICO_SECRET_KEY=
APP_PAYMENT_IYZICO_CALLBACK_URL=http://localhost:8080/api/payments/iyzico/callback
APP_PAYMENT_IYZICO_FRONTEND_BASE_URL=http://localhost:3000
APP_PAYMENT_IYZICO_DEFAULT_IDENTITY_NUMBER=
APP_PAYMENT_IYZICO_DEFAULT_BUYER_IP=
APP_PAYMENT_IYZICO_WEBHOOK_SECRET=
APP_PAYMENT_IYZICO_VERIFY_WEBHOOK_SIGNATURE=false
APP_CHECKOUT_TAX_RATE=0.20
APP_CHECKOUT_STANDARD_SHIPPING_FEE=49.90
APP_CHECKOUT_EXPRESS_SHIPPING_FEE=89.90
APP_CHECKOUT_FREE_SHIPPING_THRESHOLD=2000.00
